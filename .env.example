# Full URL of the Matchpoint backend origin (https required in production).
# Value must be the real URL — NOT the text NEXT_PUBLIC_MATCHPOINT_API_URL.
# Example: https://matchpoint.miralab.ar
NEXT_PUBLIC_MATCHPOINT_API_URL=

# Tournament detail page: poll interval in ms (5–120000). Default 30000 if unset. Set 0 to disable.
# NEXT_PUBLIC_TOURNAMENT_POLL_MS=30000
