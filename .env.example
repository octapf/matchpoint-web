# Origen del BACKEND Matchpoint (API serverless), NO la URL de matchpoint-web.
# Es otro proyecto en Vercel (repo octapf/matchpoint), p. ej. https://matchpoint.vercel.app
# Si ponés la URL de este front (p. ej. matchpoint.miralab.ar) vas a ver error 404/HTML.
NEXT_PUBLIC_MATCHPOINT_API_URL=

